# Copy to .env.local and fill in. Never commit .env.local.

# --- LLM (idea JSON): pick ONE path ---

# Azure OpenAI (recommended — uses your $50/month Azure credit)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# GPT-5 specifics (most deployments use Responses API by default):
# AZURE_OPENAI_GPT5_USE_CHAT=1
# AZURE_OPENAI_CHAT_MODEL=gpt-5.4-pro
# AZURE_OPENAI_MAX_COMPLETION_TOKENS=16384
# AZURE_OPENAI_DISABLE_RESPONSES_FALLBACK=1

# Or OpenAI.com (fallback)
# OPENAI_API_KEY=

# --- Image generation: Azure AI Foundry FLUX.2-pro ---
AZURE_FLUX_ENDPOINT=https://YOUR_RESOURCE.services.ai.azure.com/providers/blackforestlabs/v1/flux-2-pro
AZURE_FLUX_API_KEY=your_azure_flux_key_here
# Optional overrides:
# AZURE_FLUX_MODEL=FLUX.2-pro
# AZURE_FLUX_WIDTH=1024
# AZURE_FLUX_HEIGHT=1024

# --- Printify (image library uploads + mockup generation) ---
# 1. Sign in at https://printify.com
# 2. Avatar -> My account -> Connections -> Personal access tokens -> Generate new token
#    Required scopes: shops.read, uploads.write, products.write, products.read
# 3. Get your shop ID:
#    curl -H "Authorization: Bearer $PRINTIFY_API_TOKEN" https://api.printify.com/v1/shops.json
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
# Optional — pin a specific provider after first successful run (different providers
# render very different mockup styles). If unset, uses the first one returned.
# PRINTIFY_PRINT_PROVIDER_ID_PREFERRED=
# Optional — pin a specific blueprint (default is Bella Canvas 3001, usually id=6).
# PRINTIFY_BLUEPRINT_ID=6

# --- Background removal (optional — recommended for cleanest print quality) ---
# remove.bg uses AI to remove backgrounds professionally (~$0.20/image; 50 free credits/month).
# When set, replaces the algorithmic flood-fill pipeline. Falls back automatically on API error.
# Sign up at https://www.remove.bg/api to get a key.
# REMOVE_BG_API_KEY=

# --- Cost guardrail ---
# Hard cap on FLUX calls per day. 15 ideas/day = 30 calls = ~$3/day at $0.10/call.
FLUX_DAILY_CAP=15
